---
config:
  layout: dagre
  theme: dark
  fontFamily: '''Recursive Variable'', sans-serif'
  look: classic
  themeVariables:
    fontFamily: '''Recursive Variable'', sans-serif'
---
flowchart TB
    Start(["User Enters City Name"]) --> CheckEnter{"Enter Key Pressed?"}
    CheckEnter -- No --> CheckEnter
    CheckEnter -- Yes --> ValidateInput{"City Name Provided?"}
    ValidateInput -- No --> ShowAlert["Alert: Please Enter City Name"]
    ShowAlert --> CheckEnter
    ValidateInput -- Yes --> FetchCoordinates["Fetch City Coordinates<br>Nominatim API"]
    FetchCoordinates --> CheckCoordinates{"Results Found?"}
    CheckCoordinates -- No --> LogNoResults["Log: No Results Found"]
    LogNoResults --> CheckEnter
    CheckCoordinates -- Yes --> DisplayCoordinates["Display Latitude & Longitude"]
    DisplayCoordinates --> ParseLocation["Parse Location Details<br>Remove Pin Code"] & FetchWeather["Fetch Weather Data<br>OpenWeatherMap API"]
    ParseLocation --> DisplayLocation["Display State/Country"]
    FetchWeather --> ParseWeather["Extract Weather Condition<br>Temperature, Humidity,<br>Wind Speed, Precipitation"]
    ParseWeather --> MapIcon{"Map Condition<br>to Icon"}
    MapIcon --> DisplayWeather["Display Temperature<br>with Weather Icon"]
    DisplayWeather --> CalculateTime["Calculate Local Time<br>Using Timezone"]
    CalculateTime --> DisplayTime["Display Time"]
    DisplayTime --> CalculateDate["Calculate Day & Date"]
    CalculateDate --> DisplayDate["Display Day &amp; Date<br>with Ordinal"]
    DisplayDate --> End(["Weather Dashboard Updated"])